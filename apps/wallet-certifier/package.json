{
  "name": "@verii/wallet-certifier-app",
  "version": "0.1.0",
  "description": "Velocity Network Wallet Certifier web application",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "node --import tsx --import ./setup-tests.js --test 'src/**/*.test.jsx'",
    "test:ci": "NODE_ENV=test node --import tsx --import ./setup-tests.js --test --experimental-test-coverage --test-coverage-include='src/**' --test-reporter=spec --test-reporter=junit --test-reporter-destination=stdout --test-reporter-destination=test-results.junit.xml --test-reporter=lcov --test-reporter-destination=lcov.info 'src/**/*.test.jsx'",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "lint:ci": "eslint . --format json --output-file eslint-results.json",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^6.5.0",
    "@mui/material": "^6.5.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.81.0",
    "prop-types": "^15.8.1",
    "react-router": "7.15.1",
    "react-router-dom": "7.15.1"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@vitejs/plugin-react-swc": "4.3.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "expect": "30.4.1",
    "global-jsdom": "29.0.0",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "tsx": "4.22.5",
    "vite": "8.1.5"
  }
}
