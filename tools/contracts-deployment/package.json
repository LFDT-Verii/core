{
  "name": "@verii/contracts-deployment",
  "version": "1.1.3",
  "description": "A tool for deploying our contracts locally.",
  "repository": "https://github.com/LFDT-Verii/core",
  "main": "index.js",
  "bin": "index.js",
  "scripts": {
    "deploy": "node ./index.js",
    "test": "cross-env NODE_ENV=test node --test --test-concurrency=1 --experimental-test-module-mocks --experimental-test-coverage **/*.test.js --passWithNoTests",
    "lint": "eslint .",
    "lint:ci": "eslint . --format json >> eslint-results.json",
    "lint:fix": "eslint --fix ."
  },
  "author": "Itay Podhajcer",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ethers": "^6.17.0",
    "@verii/crypto": "workspace:*",
    "@verii/contract-permissions": "workspace:*",
    "@verii/metadata-registration": "workspace:*"
  }
}
