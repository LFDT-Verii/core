{
  "name": "@verii/sample-registrar-server",
  "version": "0.5.0-build",
  "private": true,
  "description": "Sample Registrar application",
  "repository": "https://github.com/LFDT-Verii/core",
  "engines": {
    "node": ">=22.22.0"
  },
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:dev": "nodemon src/standalone.js",
    "lint": "eslint .",
    "lint:ci": "eslint . --format json >> eslint-results.json",
    "lint:fix": "eslint --fix .",
    "migrate:status": "./node_modules/.bin/migrate-mongo status --file migrate-mongo.config.js",
    "migrate:create": "./node_modules/.bin/migrate-mongo create --file migrate-mongo.config.js",
    "migrate:up": "./node_modules/.bin/migrate-mongo up --file migrate-mongo.config.js",
    "migrate:down": "./node_modules/.bin/migrate-mongo down --file migrate-mongo.config.js"
  },
  "author": "Yauheni Pozdnyakov",
  "license": "Apache-2.0",
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/basic-auth": "^6.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@spencejs/spence-mongo-repos": "^1.1.0",
    "@verii/auth": "workspace:*",
    "@verii/aws-clients": "workspace:*",
    "@verii/base-contract-io": "workspace:*",
    "@verii/common-schemas": "workspace:*",
    "@verii/config": "workspace:*",
    "@verii/country-data": "workspace:*",
    "@verii/endpoints-credential-types-registrar": "workspace:*",
    "@verii/endpoints-event-processing": "workspace:*",
    "@verii/endpoints-organizations-registrar": "workspace:*",
    "@verii/fastify-plugins": "workspace:*",
    "@verii/server-provider": "workspace:*",
    "@verii/validation": "workspace:*",
    "env-var": "^7.5.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "http-errors": "^2.0.1",
    "lodash": "^4.18.0"
  },
  "devDependencies": {
    "@spencejs/spence-factories": "^1.1.0",
    "@verii/db-kms": "workspace:*",
    "@verii/organizations-registry": "workspace:*",
    "@verii/tests-helpers": "workspace:*",
    "dotenv": "^17.4.2",
    "eslint": "9.39.4",
    "eslint-config-airbnb-extended": "3.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-better-mutation": "2.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prefer-arrow-functions": "3.9.1",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-watch": "8.0.0",
    "expect": "30.4.1",
    "globals": "17.6.0",
    "migrate-mongo": "14.0.7",
    "nodemon": "3.1.14",
    "prettier": "3.8.3"
  }
}
