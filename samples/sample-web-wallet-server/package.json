{
  "name": "@verii/sample-web-wallet-server",
  "version": "0.5.0-build",
  "description": "Sample VNF Wallet Nodejs Server",
  "repository": "https://github.com/LFDT-Verii/core",
  "scripts": {
    "lint": "eslint src",
    "lint:fix": "eslint --fix src",
    "lint:ci": "eslint --format json >> eslint-results.json src",
    "test": "node --enable-source-maps --import=global-jsdom/register --import=tsx --test --test-reporter=spec --test-reporter-destination=stdout '**/*.test.ts' '**/*.test.tsx'",
    "test:ci": "node --enable-source-maps --import=global-jsdom/register --import=tsx --test --experimental-test-coverage --test-reporter=spec --test-reporter=junit --test-reporter-destination=stdout --test-reporter-destination=test-results.junit.xml --test-reporter=lcov --test-reporter-destination=lcov.info '**/*.test.ts' '**/*.test.tsx'",
    "build": "tsc",
    "prepublishOnly": "tsc",
    "start": "node ./dist/Server.js",
    "start:dev": "tsx src/Server.ts"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">= 22.22.0"
  },
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/cors": "^11.2.0",
    "@verii/vc-checks": "workspace:*",
    "@verii/vnf-nodejs-wallet-sdk": "workspace:*",
    "env-var": "^7.5.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "24.13.2",
    "eslint": "9.39.4",
    "eslint-config-airbnb-extended": "3.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-better-mutation": "2.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prefer-arrow-functions": "3.9.1",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-unused-imports": "4.4.1",
    "expect": "30.4.1",
    "global-jsdom": "29.0.0",
    "globals": "17.7.0",
    "json-schema-to-ts": "3.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.2"
  },
  "nx": {
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/dist"
        ]
      },
      "test": {
        "dependsOn": [
          "^build"
        ]
      }
    }
  }
}
