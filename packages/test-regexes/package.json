{
  "name": "@verii/test-regexes",
  "version": "1.1.3",
  "description": "Set of regexes for tests",
  "repository": "https://github.com/LFDT-Verii/core",
  "main": "index.js",
  "author": "Andres Olave",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "cross-env NODE_ENV=test node --test --test-concurrency=1 --experimental-test-module-mocks --experimental-test-coverage **/*.test.js --passWithNoTests",
    "lint": "eslint .",
    "lint:ci": "eslint . --format json >> eslint-results.json",
    "lint:fix": "eslint --fix ."
  },
  "devDependencies": {
    "eslint": "9.39.4",
    "eslint-config-airbnb-extended": "3.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-better-mutation": "2.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prefer-arrow-functions": "3.9.1",
    "eslint-plugin-prettier": "5.5.5",
    "expect": "30.4.1",
    "globals": "17.7.0",
    "prettier": "3.8.3"
  }
}
