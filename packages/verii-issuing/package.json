{
  "name": "@verii/verii-issuing",
  "version": "1.1.3",
  "description": "Verii Issuing Package",
  "repository": "https://github.com/LFDT-Verii/core",
  "main": "src/index.js",
  "types": "types/types.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "cross-env NODE_ENV=test node --test --test-concurrency=1 --experimental-test-module-mocks --experimental-test-coverage --test-reporter=spec --test-reporter-destination=stdout 'test/**/*.test.js'",
    "test:ci": "cross-env NODE_ENV=test node --test --test-concurrency=1 --experimental-test-module-mocks --experimental-test-coverage --test-coverage-include='src/**' --test-reporter=spec --test-reporter=junit --test-reporter-destination=stdout --test-reporter-destination=test-results.junit.xml --test-reporter=lcov --test-reporter-destination=lcov.info 'test/**/*.test.js'",
    "lint": "eslint .",
    "lint:ci": "eslint . --format json >> eslint-results.json",
    "lint:fix": "eslint --fix ."
  },
  "author": "Andres Olave",
  "license": "Apache-2.0",
  "dependencies": {
    "@verii/blockchain-functions": "workspace:*",
    "@verii/common-functions": "workspace:*",
    "@verii/crypto": "workspace:*",
    "@verii/did-doc": "workspace:*",
    "@verii/jwt": "workspace:*",
    "@verii/metadata-registration": "workspace:*",
    "@verii/vc-checks": "workspace:*",
    "canonicalize": "^2.1.0",
    "eth-url-parser": "^1.0.4",
    "fast-shuffle": "6.1.1",
    "lodash": "^4.18.1"
  },
  "devDependencies": {
    "@verii/contract-permissions": "workspace:*",
    "@verii/http-client": "workspace:*",
    "@verii/test-regexes": "workspace:*",
    "@verii/tests-helpers": "workspace:*",
    "eslint": "9.39.4",
    "eslint-config-airbnb-extended": "3.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-better-mutation": "2.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-prefer-arrow-functions": "3.9.1",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-watch": "8.0.0",
    "expect": "30.4.1",
    "globals": "17.6.0",
    "mongodb": "^7.3.0",
    "nanoid": "^5.1.15",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.2"
  },
  "nx": {
    "tags": [
      "lib"
    ]
  }
