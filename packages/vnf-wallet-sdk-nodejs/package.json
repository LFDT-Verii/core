{
  "name": "@verii/vnf-nodejs-wallet-sdk",
  "version": "0.5.0-build",
  "description": "VNF Wallet SDK Nodejs",
  "repository": "https://github.com/LFDT-Verii/core",
  "author": "Andres Olave",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "eslint . --format json >> eslint-results.json",
    "lint:fix": "eslint --fix .",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "prepublishOnly": "tsc --declaration",
    "test": "cross-env NODE_ENV=test node --enable-source-maps --import=tsx --test --test-reporter=spec --test-reporter-destination=stdout '**/*.test.ts' '**/*.test.tsx'",
    "test:ci": "cross-env NODE_ENV=test node --enable-source-maps --import=tsx --test --experimental-test-coverage --test-reporter=spec --test-reporter=junit --test-reporter-destination=stdout --test-reporter-destination=test-results.junit.xml --test-reporter=lcov --test-reporter-destination=lcov.info '**/*.test.ts' '**/*.test.tsx'"
  },
  "engines": {
    "node": ">= 22.22.0"
  },
  "dependencies": {
    "@verii/http-client": "0.5.0-build",
    "@verii/vc-checks": "^0.5.0-build",
    "canonicalize": "^2.1.0",
    "jose": "^5.10.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "24.12.3",
    "@verii/test-regexes": "^0.5.0-build",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prefer-arrow-functions": "3.9.1",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-unused-imports": "4.4.1",
    "expect": "30.4.1",
    "nock": "15.0.0-beta.11",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "files": [
    "/dist"
  ],
  "nx": {
    "tags": [
      "lib"
    ]
  }
}
