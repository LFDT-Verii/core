  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@fastify/jwt": "^10.1.0",
    "fastify-auth0-verify": "^4.1.1",
    "fastify-plugin": "^5.1.0",
    "http-errors": "^2.0.1",
    "lodash": "^4.18.1"
  },
  "devDependencies": {
    "eslint": "9.39.5",
    "eslint-config-airbnb-extended": "3.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-better-mutation": "2.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prefer-arrow-functions": "3.10.1",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-watch": "8.0.0",
    "expect": "30.4.1",
    "fastify": "^5.9.0",
    "globals": "17.7.0",
    "nock": "15.0.0-beta.12",
    "prettier": "3.9.5"
  },
  "nx": {
    "tags": [
      "lib"
    ]
  }
