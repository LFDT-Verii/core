{
  "name": "@verii/server-provider",
  "version": "1.1.3",
  "description": "Server common package for Velocity Projects ",
  "repository": "https://github.com/LFDT-Verii/core",
  "main": "index.js",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "cross-env NODE_ENV=test node --test --test-concurrency=1 --experimental-test-module-mocks --experimental-test-coverage --test-reporter=spec --test-reporter-destination=stdout 'test/**/*.test.js'",
    "test:ci": "NODE_ENV=test node --test --test-concurrency=1 --experimental-test-module-mocks --experimental-test-coverage --test-coverage-include='src/**' --test-reporter=spec --test-reporter=junit --test-reporter-destination=stdout --test-reporter-destination=test-results.junit.xml --test-reporter=lcov --test-reporter-destination=lcov.info 'test/**/*.test.js'",
    "lint": "eslint .",
    "lint:ci": "eslint . --format json >> eslint-results.json",
    "lint:fix": "eslint --fix ."
  },
  "dependencies": {
    "@spencejs/spence-events": "^1.1.0",
    "@spencejs/spence-mongo-repos": "^1.1.0",
    "@verii/common-functions": "workspace:*",
    "@verii/common-schemas": "workspace:*",
    "@verii/fastify-plugins": "workspace:*",
    "@verii/logger": "workspace:*",
    "@verii/rest-queries": "workspace:*",
    "ajv-formats": "3.0.1",
    "http-errors": "^2.0.1",
    "lodash": "^4.18.1",
    "nanoid": "^5.1.11"
  },
  "peerDependencies": {
    "@fastify/helmet": ">=11.1.1",
    "@fastify/sensible": ">=5.6.0",
    "@fastify/swagger": ">=8.15.0",
    "@fastify/swagger-ui": ">=4.2.0",
    "fastify": ">=4.29.0",
    "fastify-plugin": ">=4.5.1"
  },
  "devDependencies": {
    "@verii/config": "workspace:*",
    "@verii/http-client": "workspace:*",
    "@verii/tests-helpers": "workspace:*",
    "eslint": "9.39.4",
    "eslint-config-airbnb-extended": "3.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-better-mutation": "2.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prefer-arrow-functions": "3.9.1",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-watch": "8.0.0",
    "expect": "30.4.1",
    "fastify": "^5.8.5",
    "globals": "17.6.0",
    "h2url": "0.2.0",
    "prettier": "3.8.3"
  },
  "nx": {
    "tags": [
      "lib"
    ]
  }
}
