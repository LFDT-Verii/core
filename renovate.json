{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "timezone": "Asia/Jerusalem",
  "extends": [
    "config:best-practices",
    "security:minimumReleaseAgeNpm",
    "group:allDigest",
    "group:linters",
    "group:jsTest",
    "group:postcss",
    "group:react",
    "group:vite",
    "security:openssf-scorecard",
    ":enableVulnerabilityAlertsWithLabel(security)"
  ],
  "prHourlyLimit": 10,
  "addLabels": [
    "dependencies"
  ],
  "automerge": true,
  "schedule": [
    "* 0-2 * * 1,3"
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "npm"
      ],
      "matchCurrentValue": "/^[~^][1-9]\\d*\\.\\d+\\.\\d+$/",
      "rangeStrategy": "bump",
      "description": "Keep stable npm semver ranges current in package manifests so shared pnpm lockfile refreshes don't split into lockfile-only PRs."
    },
    {
      "matchDatasources": [
        "npm"
      ],
      "matchCurrentValue": "/^[~^]?0\\./",
      "automerge": false,
      "description": "Pre-1.0 npm packages may break in minor or patch releases, so require review."
    },
    {
      "matchPackageNames": [
        "nock"
      ],
      "allowedVersions": "!/^15\\.0\\.0$/",
      "description": "Block the accidentally published nock 15.0.0 release while still allowing other nock updates."
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "addLabels": [
        "major"
      ],
      "automerge": false,
      "schedule": [
        "* 0-2 1,15 * *"
      ]
    },
    {
      "groupName": "group: fastify packages",
      "matchPackageNames": [
        "@fastify/{/,}**",
        "fastify{/,}**",
        "avvio{/,}**",
        "fast-json{/,}**",
        "fast-jwt{/,}**",
        "pino{/,}**"
      ]
    },
    {
      "matchFileNames": [
        "eng/**",
        ".github/**",
        "docker*.yml",
        "Dockerfile*"
      ],
      "addLabels": [
        "eng"
      ]
    },
    {
      "matchFileNames": [
        "contracts/**"
      ],
      "addLabels": [
        "contracts"
      ],
      "automerge": false,
      "schedule": [
        "* 0-2 1,15 * *"
      ]
    },
    {
      "groupName": "group: auth0 packages",
      "matchPackageNames": [
        "@auth0/{/,}**",
        "auth0{/,}**"
      ],
      "automerge": false
    },
    {
      "groupName": "group: spence packages",
      "matchPackageNames": [
        "@spencejs/{/,}**"
      ]
    },
    {
      "matchPackageNames": [
        "twilio{/,}**",
        "ethers{/,}**",
        "@sentry/{/,}**"
      ],
      "automerge": false
    },
    {
      "matchPackageNames": [
        "@aws-sdk/{/,}**"
      ],
      "extends": [
        "schedule:monthly"
      ],
      "automerge": false
    },
    {
      "matchPackageNames": [
        "nx",
        "@nx/{/,}**"
      ],
      "enabled": false
    },
    {
      "groupName": "group: hardhat compatibility set",
      "matchPackageNames": [
        "hardhat",
        "@openzeppelin/hardhat-upgrades",
        "@nomicfoundation/hardhat-ethers"
      ],
      "minimumGroupSize": 3,
      "automerge": false,
      "description": "Temporary coupling: keep hardhat updates grouped with @openzeppelin/hardhat-upgrades & @nomicfoundation/hardhat-ethers until Hardhat v3 compatibility."
    }
  ]
}
