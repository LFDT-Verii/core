FROM node:24.18.0-slim@sha256:b31e7a42fdf8b8aa5f5ed477c72d694301273f1069c5a2f71d53c6482e99a2fc AS builder
ARG NODE_ENV=production
ARG SERVICE
WORKDIR /app
RUN chown -R node:node /app

USER root

RUN apt-get update \
  && apt-get install -y --no-install-recommends  python3 make g++ \
  && ln -sf python3 /usr/bin/python \
  && corepack enable \
  && corepack prepare pnpm@10.30.2 --activate

USER node

COPY --chown=node:node package*.json pnpm-lock.yaml pnpm-workspace.yaml lerna.json ./
COPY --chown=node:node .husky ./.husky
COPY --chown=node:node packages ./packages
COPY --chown=node:node servers ./servers
COPY --chown=node:node samples ./samples
RUN HUSKY=0 pnpm install --frozen-lockfile

FROM node:24.18.0-slim@sha256:b31e7a42fdf8b8aa5f5ed477c72d694301273f1069c5a2f71d53c6482e99a2fc
ARG SERVICE
WORKDIR /app
RUN corepack enable \
  && corepack prepare pnpm@10.30.2 --activate
COPY --chown=node:node --from=builder /app .
USER node
WORKDIR "/app/servers/$SERVICE"

EXPOSE 3000
ENTRYPOINT ["pnpm", "start"]
