{
  "$id": "revoke-credential",
  "type": "object",
  "title": "Revoke credential",
  "description": "Payload schema for revoking an issued credential",
  "additionalProperties": false,
  "properties": {
    "tenantId": {
      "type": "string"
    },
    "credentialId": {
      "type": "string",
      "minLength": 1
    },
    "message": {
      "type": "string"
    },
    "linkedCredential": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "credentialId": {
          "type": "string",
          "minLength": 1
        },
        "credentialType": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["credentialType"]
    }
  },
  "required": ["tenantId", "credentialId"]
}
