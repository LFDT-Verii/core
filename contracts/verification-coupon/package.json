{
  "name": "@verii/verification-coupon-contract",
  "version": "0.5.0-build",
  "description": "",
  "scripts": {
    "test": "hardhat test",
    "assert:target-env": "node ../test-utils/assert-target-env.js",
    "test:post-upgrade": "node ../test-utils/assert-target-env.js && POST_UPGRADE_SMOKE=1 hardhat test test/smoke/post-upgrade.smoke.test.js --network $TARGET_ENV",
    "build:hardhat": "hardhat compile",
    "clean:hardhat": "hardhat clean",
    "hardhat:deploy": "node ../test-utils/assert-target-env.js && hardhat run hardhat/deploy.js --network $TARGET_ENV",
    "hardhat:upgrade": "node ../test-utils/assert-target-env.js && hardhat run hardhat/upgrade.js --network $TARGET_ENV"
  },
  "author": "",
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "dependencies": {},
  "devDependencies": {
    "@openzeppelin/contracts": "4.9.6",
    "@openzeppelin/contracts-upgradeable": "4.9.6",
    "@verii/permissions-contract": "^0.5.0-build",
    "ethers": "^6.16.0"
  }
}
